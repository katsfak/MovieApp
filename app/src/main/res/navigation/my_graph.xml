<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/my_graph"
    xmlns:tools="http://schemas.android.com/tools"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.movieapp.ui.auth.LoginFragment"
        android:label="LoginFragment"
        tools:layout="@layout/login_layout">
        <action
            android:id="@+id/action_loginFragment_to_signupFragment"
            app:destination="@id/signupFragment" />
        <action
            android:id="@+id/action_loginFragment_to_movieListFragment"
            app:destination="@id/movieListFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/signupFragment"
        android:name="com.example.movieapp.ui.auth.SignupFragment"
        android:label="SignupFragment"
        tools:layout="@layout/signup_layout">
        <action
            android:id="@+id/action_signupFragment_to_movieListFragment"
            app:destination="@id/movieListFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/movieListFragment"
        android:name="com.example.movieapp.ui.homeScreen.MovieListFragment"
        android:label="MovieListFragment"
        tools:layout="@layout/fragment_movie">
        <action
            android:id="@+id/action_movieListFragment_to_detailsScreen"
            app:destination="@id/detailsScreen" />
        <action
            android:id="@+id/action_movieListFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.movieapp.ui.profile.ProfileFragment"
        android:label="ProfileFragment"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profileFragment_to_favoritesFragment"
            app:destination="@id/favoritesFragment" />
        <action
            android:id="@+id/action_profileFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/movieListFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/favoritesFragment"
        android:name="com.example.movieapp.ui.profile.FavoritesFragment"
        android:label="FavoritesFragment"
        tools:layout="@layout/fragment_favorites">
        <action
            android:id="@+id/action_favoritesFragment_to_detailsScreen"
            app:destination="@id/detailsScreen" />
    </fragment>

    <fragment
        android:id="@+id/detailsScreen"
        android:name="com.example.movieapp.ui.detailsScreen.DetailsScreen"
        tools:layout="@layout/details_layout"
        android:label="DetailsScreen">
        <argument
            android:name="movieId"
            app:argType="integer"
            android:defaultValue="-1" />
        <action
            android:id="@+id/action_detailsScreen_to_reviewsListFragment"
            app:destination="@id/reviewsListFragment" />
    </fragment>

    <fragment
        android:id="@+id/reviewsListFragment"
        android:name="com.example.movieapp.ui.detailsScreen.ReviewsListFragment"
        tools:layout="@layout/all_reviews_layout"
        android:label="ReviewsListFragment">
        <argument
            android:name="reviews"
            app:argType="com.example.movieapp.domain.models.ReviewsUi[]" />
    </fragment>
</navigation>